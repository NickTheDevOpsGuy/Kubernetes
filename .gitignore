# ============================
# 🌍 Universal .gitignore for kubernates repo
# Covers OS junk, Kubernetes, Helm, Terraform, Node.js, Python, IDEs, secrets
# ============================

# ---- macOS ----
.DS_Store
.AppleDouble
.LSOverride
Icon?
._*

# ---- Windows ----
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# ---- Linux ----
*~
.nfs*

# ---- Editor swap / temp ----
*.swp
*.swo
*.tmp
*.bak
*.log

# ---- Node.js ----
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock
pnpm-lock.yaml
dist/
build/
coverage/
.cache/
.next/          # Next.js
.nuxt/          # Nuxt.js
out/            # static builds
*.tsbuildinfo   # TS incremental build cache

# ---- Python (if experimenting) ----
venv/
__pycache__/
*.pyc

# ---- Kubernetes / Helm ----
.kube/
*.kubeconfig
charts/*/charts/
charts/*/tmpcharts/
*.tgz

# ---- Terraform (future labs) ----
*.tfstate
*.tfstate.backup
.terraform/
.terraform.lock.hcl

# ---- IDE / Editor configs ----
.vscode/
.idea/
*.iml

# ---- Secrets / Credentials ----
*.env
.env.*
secrets*.yaml